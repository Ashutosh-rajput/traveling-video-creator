# ===========================================================================
# Voyageur AI Studio — Environment Configuration (Example)
# Copy this file to '.env' and fill in your private API credentials.
# Lines starting with '#' are comments. Never commit your real .env.
# ===========================================================================

# ---------------------------------------------------------------------------
# Application Settings
# ---------------------------------------------------------------------------
APP_NAME="Voyageur AI Studio"       # Display name of the app (any text)
APP_ENV=local                       # Runtime environment: local | staging | production
DEBUG=true                          # Verbose logs + debug tool output: true | false (use false in production)
API_V1_PREFIX=/api/v1               # URL prefix mounted before every API route

# ---------------------------------------------------------------------------
# Google AI Studio / Gemini API
# ---------------------------------------------------------------------------
# Required. Powers the LLM that writes scripts and calls media tools.
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_ai_studio_api_key

# ---------------------------------------------------------------------------
# Gemma LLM Settings
# ---------------------------------------------------------------------------
GEMMA_MODEL=gemma-4-31b-it          # Model id. Supported: gemma-4-31b-it, gemma-4-26b-a4b-it
LLM_TEMPERATURE=0.2                 # Creativity/randomness, 0.0 (focused) .. 1.0 (creative)
LLM_MAX_OUTPUT_TOKENS=4096          # Max tokens the model may generate per request
REQUEST_TIMEOUT_SECONDS=120         # Seconds to wait for an LLM response before timing out

# ---------------------------------------------------------------------------
# Media Curation Provider API Keys
# ---------------------------------------------------------------------------
# Optional — each is used to search real travel photos/videos. Providers with a
# missing key are skipped gracefully (the app still works with the others).
PEXELS_API_KEY=your_pexels_api_key           # https://www.pexels.com/api/  (photos + videos)
PIXABAY_API_KEY=your_pixabay_api_key         # https://pixabay.com/api/docs/ (photos + videos)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key # https://unsplash.com/developers (photos only)

# ---------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing) Allowed Origins
# ---------------------------------------------------------------------------
# JSON array of frontend URLs allowed to call this API. Add your deployed
# frontend origin here. Must be valid JSON (double quotes, no trailing comma).
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174"]

# ---------------------------------------------------------------------------
# Cloudflare Workers AI — Optional AI intro banner image generation
# ---------------------------------------------------------------------------
# Powers the optional "AI-Generated Banner" intro (default intro is static text).
# Free tier: ~10,000 neurons/day. Create a token at My Profile > API Tokens with
# the "Workers AI" template. Leave blank to disable AI intro images.
CLOUDFLARE_ACCOUNT_ID=              # Account ID from the Cloudflare dashboard sidebar
CLOUDFLARE_API_TOKEN=               # API token with Workers AI read/edit permission
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell  # text-to-image model id

# ---------------------------------------------------------------------------
# Sarvam AI — Text-to-Speech (Bulbul Engine)
# ---------------------------------------------------------------------------
# Required for voiceover generation. Get a key at https://www.sarvam.ai/
SARVAM_API_KEY=your_sarvam_api_key
SARVAM_LANG=en-IN                   # Voiceover language/locale: en-IN, hi-IN, bn-IN, ta-IN, te-IN, gu-IN, kn-IN, ml-IN, mr-IN, pa-IN, od-IN
SARVAM_SPEAKER=shubh                # Voice/speaker id (e.g. shubh); must exist for the chosen model
SARVAM_PACE=1.0                     # Speech speed: <1.0 slower, 1.0 normal, >1.0 faster (e.g. 1.1, 1.2)
SARVAM_SAMPLE_RATE=24000            # Audio sample rate in Hz: 8000 | 16000 | 22050 | 24000
SARVAM_MODEL=bulbul:v3              # TTS model version (e.g. bulbul:v3)

# ---------------------------------------------------------------------------
# Video Render Tuning — Memory / Size
# ---------------------------------------------------------------------------
# Lower these to avoid out-of-memory on small hosts. On a 1 GB instance
# (e.g. Railway free tier) set VIDEO_MAX_LONG_EDGE=1280 for 720p — roughly half
# the frame memory. Use 960 for 540p if 720p still OOMs.
VIDEO_MAX_LONG_EDGE=1920            # Output resolution cap: 1920=1080p, 1280=720p, 960=540p
RENDER_THREADS=4                    # ffmpeg encode threads; fewer = less memory, slower encode

# Render engine: "ffmpeg" (fast native assembly, recommended) or "moviepy" (legacy fallback)
RENDER_ENGINE=ffmpeg

# ---------------------------------------------------------------------------
# Video Render Tuning — Output Quality
# ---------------------------------------------------------------------------
# Higher quality = larger files + slower/heavier encodes. Dial DOWN (toward
# ultrafast / 23-28) on CPU- or memory-limited hosts if renders time out or OOM;
# dial UP for best-looking output on a strong host.

# RENDER_PRESET — x264 speed vs compression. Slower = better quality per byte.
#   Values (fastest→slowest): ultrafast, superfast, veryfast, faster, fast,
#   medium, slow, slower, veryslow. (ultrafast=weak host, medium=balanced, slow=best)
RENDER_PRESET=medium

# RENDER_CRF — constant quality, 0 (lossless) .. 51 (worst). Lower = better + bigger.
#   Each +6 roughly halves the file size. 18=visually lossless, 23=default, 28=small
RENDER_CRF=18

# RENDER_FPS — output frames per second.
#   24 = cinematic/lighter, 30 = smooth (default), 60 = very smooth but ~2x frames
RENDER_FPS=30

# RENDER_AUDIO_BITRATE — AAC audio bitrate for voiceover/music track.
#   128k = acceptable, 160k = good, 192k = high (default), 256k = very high
RENDER_AUDIO_BITRATE=192k

# ---------------------------------------------------------------------------
# Reddit API (Optional) — used by the /chat/reddit-search endpoint
# ---------------------------------------------------------------------------
# Create a "script" app at https://www.reddit.com/prefs/apps to get these.
# Leave blank to disable Reddit search.
REDDIT_CLIENT_ID=                   # Reddit app client id
REDDIT_CLIENT_SECRET=               # Reddit app client secret

# ---------------------------------------------------------------------------
# Google Drive Upload (Optional) — OAuth for "Connect Drive" video upload
# ---------------------------------------------------------------------------
# In Google Cloud Console, add the exact GDRIVE_REDIRECT_URI below to your OAuth
# client's Authorized redirect URIs before using Connect Drive.
G_DRIVE_FOLDER_ID=                  # Target Drive folder id to upload into (blank = Drive root)
GDRIVE_CLIENT_ID=                   # OAuth client id from Google Cloud Console
GDRIVE_CLIENT_SECRET=               # OAuth client secret from Google Cloud Console
GDRIVE_REDIRECT_URI=http://localhost:8000/api/v1/login/google/callback  # Must match the URI registered in Google Cloud
GDRIVE_REFRESH_TOKEN=               # Auto-filled after you connect Drive once; leave blank initially
