# ===========================================================================
# Voyageur AI Studio Environment Configurations Example
# Copy this file to '.env' and fill in your private API credentials.
# ===========================================================================

# Application Settings
APP_NAME="Voyageur AI Studio"
APP_ENV=local                       # Possible values: local, staging, production
DEBUG=true                          # Possible values: true, false
API_V1_PREFIX=/api/v1               # Prefix path for all API routes

# Google AI Studio / Gemini API Configuration
GOOGLE_API_KEY=your_google_ai_studio_api_key

# Gemma LLM Settings
# Supported models include: gemma-4-31b-it, gemma-4-26b-a4b-it
GEMMA_MODEL=gemma-4-31b-it
LLM_TEMPERATURE=0.2                 # Temperature value between 0.0 and 1.0
LLM_MAX_OUTPUT_TOKENS=4096          # Max tokens to generate per request
REQUEST_TIMEOUT_SECONDS=120         # Maximum time to wait for AI generation response

# Media Curation Provider API Keys
# Optional but required to search and curate real travel photos/videos
PEXELS_API_KEY=your_pexels_api_key
PIXABAY_API_KEY=your_pixabay_api_key
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# CORS Cross-Origin Resource Sharing Allowed Origins
# Must be a JSON array of URLs (strings) that are allowed to make requests to the API
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174"]

# Sarvam AI (TTS / Bulbul v3 Engine) Configuration
SARVAM_API_KEY=your_sarvam_api_key
SARVAM_PACE=1.0                     # Speech speed rate (e.g. 1.0, 1.1, 1.2)
SARVAM_SAMPLE_RATE=24000            # Sample rate (e.g. 24000, 44100)
SARVAM_MODEL=bulbul:v3              # TTS model version (e.g. bulbul:v3)
